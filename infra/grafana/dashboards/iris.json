{
  "uid": "marin-iris",
  "title": "Iris resources",
  "description": "Per-task and per-worker resource usage from the iris.task and iris.worker finelog namespaces. A busy cluster runs hundreds of tasks, so each panel shows only the 20 heaviest series over the window (a full per-task scan overruns the bridge row cap). iris.task is written on every backend, so this dashboard has data on marin-dev; iris.worker heartbeats are GCE/TPU-only.",
  "tags": [
    "marin",
    "generated"
  ],
  "timezone": "utc",
  "editable": false,
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "datasource",
        "query": "yesoreyeram-infinity-datasource",
        "current": {
          "text": "finelog-marin",
          "value": "finelog-marin"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Top tasks by memory",
      "description": "The 20 tasks with the highest mean resident memory over the window, from iris.task.memory_mb.",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${cluster}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "timeseries",
          "parser": "backend",
          "url": "/query",
          "url_options": {
            "method": "GET",
            "params": [
              {
                "key": "sql",
                "value": "WITH top AS (SELECT task_id FROM \"iris.task\" WHERE ts >= {{from}} AND ts < {{to}} GROUP BY task_id ORDER BY AVG(memory_mb) DESC LIMIT 20) SELECT date_bin(INTERVAL '${__interval_ms} milliseconds', ts) AS t, task_id AS series, AVG(memory_mb) AS value FROM \"iris.task\" WHERE ts >= {{from}} AND ts < {{to}} AND task_id IN (SELECT task_id FROM top) GROUP BY 1, 2 ORDER BY 1"
              },
              {
                "key": "from",
                "value": "${__from}"
              },
              {
                "key": "to",
                "value": "${__to}"
              }
            ]
          },
          "columns": [
            {
              "selector": "t",
              "text": "time",
              "type": "timestamp_epoch"
            },
            {
              "selector": "series",
              "text": "task",
              "type": "string"
            },
            {
              "selector": "value",
              "text": "memory_mb",
              "type": "number"
            }
          ]
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
