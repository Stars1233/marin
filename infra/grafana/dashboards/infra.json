{
  "uid": "infra",
  "title": "Infra",
  "description": "Marin infra status: GitHub build/ferry health, the live Iris control plane, and the infra/probes canary namespace. Replaces the standalone status page; panels read the Grafana bridge's fixed GitHub/Iris endpoints and finelog SQL.",
  "tags": [
    "marin"
  ],
  "timezone": "utc",
  "editable": false,
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
