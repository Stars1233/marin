    {
      "id": 12,
      "type": "table",
      "title": "Latest health checks",
      "description": "Latest probe_up and probe_latency_ms per synthetic health check, keyed by the probe label.",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "finelog-marin"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 31
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "filterable": true
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "parser": "backend",
          "url": "/query",
          "url_options": {
            "method": "GET",
            "params": [
              {
                "key": "sql",
                "value": "WITH recent AS (SELECT labels, metric, value, ROW_NUMBER() OVER (PARTITION BY labels, metric ORDER BY collected_at DESC) AS rn FROM \"infra.canary.metrics\" WHERE metric IN ('probe_up', 'probe_latency_ms') AND collected_at >= {{from}} AND collected_at < {{to}}) SELECT json_get(labels, 'probe') AS probe, metric, value FROM recent WHERE rn = 1 ORDER BY probe, metric"
              },
              {
                "key": "from",
                "value": "${__from}"
              },
              {
                "key": "to",
                "value": "${__to}"
              }
            ]
          },
          "columns": [
            {
              "selector": "probe",
              "text": "probe",
              "type": "string"
            },
            {
              "selector": "metric",
              "text": "metric",
              "type": "string"
            },
            {
              "selector": "value",
              "text": "value",
              "type": "number"
            }
          ]
        }
      ]
    },
