{
  "uid": "marin-pipelines",
  "title": "Pipelines",
  "description": "Zephyr pipeline throughput and shard resource usage from the zephyr.worker finelog namespace, summed or averaged across a stage's running shards.",
  "tags": [
    "marin",
    "generated"
  ],
  "timezone": "utc",
  "editable": false,
  "schemaVersion": 39,
  "refresh": "1m",
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "cluster",
        "label": "Cluster",
        "type": "datasource",
        "query": "yesoreyeram-infinity-datasource",
        "current": {
          "text": "finelog-marin",
          "value": "finelog-marin"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Item rate by stage",
      "description": "Items per second summed across a stage's running shards, from zephyr.worker.item_rate.",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${cluster}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "timeseries",
          "parser": "backend",
          "url": "/query",
          "url_options": {
            "method": "GET",
            "params": [
              {
                "key": "sql",
                "value": "SELECT date_bin(INTERVAL '${__interval_ms} milliseconds', ts) AS t, stage_name AS series, SUM(item_rate) AS value FROM \"zephyr.worker\" WHERE status = 'RUNNING' AND ts >= {{from}} AND ts < {{to}} GROUP BY 1, 2 ORDER BY 1"
              },
              {
                "key": "from",
                "value": "${__from}"
              },
              {
                "key": "to",
                "value": "${__to}"
              }
            ]
          },
          "columns": [
            {
              "selector": "t",
              "text": "time",
              "type": "timestamp_epoch"
            },
            {
              "selector": "series",
              "text": "stage",
              "type": "string"
            },
            {
              "selector": "value",
              "text": "items_per_s",
              "type": "number"
            }
          ]
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Throughput by stage",
      "description": "Bytes per second summed across a stage's running shards, from zephyr.worker.byte_rate.",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${cluster}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "timeseries",
          "parser": "backend",
          "url": "/query",
          "url_options": {
            "method": "GET",
            "params": [
              {
                "key": "sql",
                "value": "SELECT date_bin(INTERVAL '${__interval_ms} milliseconds', ts) AS t, stage_name AS series, SUM(byte_rate) AS value FROM \"zephyr.worker\" WHERE status = 'RUNNING' AND ts >= {{from}} AND ts < {{to}} GROUP BY 1, 2 ORDER BY 1"
              },
              {
                "key": "from",
                "value": "${__from}"
              },
              {
                "key": "to",
                "value": "${__to}"
              }
            ]
          },
          "columns": [
            {
              "selector": "t",
              "text": "time",
              "type": "timestamp_epoch"
            },
            {
              "selector": "series",
              "text": "stage",
              "type": "string"
            },
            {
              "selector": "value",
              "text": "bytes_per_s",
              "type": "number"
            }
          ]
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Shard memory by stage",
      "description": "Mean resident memory across a stage's running shards, from zephyr.worker.mem_current_bytes.",
      "datasource": {
        "type": "yesoreyeram-infinity-datasource",
        "uid": "${cluster}"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "drawStyle": "line",
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "timeseries",
          "parser": "backend",
          "url": "/query",
          "url_options": {
            "method": "GET",
            "params": [
              {
                "key": "sql",
                "value": "SELECT date_bin(INTERVAL '${__interval_ms} milliseconds', ts) AS t, stage_name AS series, AVG(mem_current_bytes) AS value FROM \"zephyr.worker\" WHERE status = 'RUNNING' AND ts >= {{from}} AND ts < {{to}} GROUP BY 1, 2 ORDER BY 1"
              },
              {
                "key": "from",
                "value": "${__from}"
              },
              {
                "key": "to",
                "value": "${__to}"
              }
            ]
          },
          "columns": [
            {
              "selector": "t",
              "text": "time",
              "type": "timestamp_epoch"
            },
            {
              "selector": "series",
              "text": "stage",
              "type": "string"
            },
            {
              "selector": "value",
              "text": "mem_bytes",
              "type": "number"
            }
          ]
        }
      ]
    }
  ]
}
